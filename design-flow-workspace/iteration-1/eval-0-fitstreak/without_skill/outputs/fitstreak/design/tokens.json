{
  "name": "FitStreak Design Tokens",
  "version": "1.0.0",
  "platform": ["iOS", "Android"],
  "updated": "2026-03-22",
  "description": "FitStreak 健身打卡应用设计 Token 系统，基于 React Native 实现",

  "colors": {
    "primary": {
      "base": "#6C63FF",
      "light": "#8B85FF",
      "dark": "#5A52D5",
      "lighter": "#E8E7FF",
      "alpha_10": "#6C63FF1A",
      "alpha_20": "#6C63FF33",
      "alpha_50": "#6C63FF80"
    },
    "secondary": {
      "base": "#00C9A7",
      "light": "#4DDEBD",
      "dark": "#00A78A",
      "lighter": "#E6FAF6"
    },
    "success": {
      "base": "#00C853",
      "light": "#69F0AE",
      "dark": "#00A344",
      "lighter": "#E8F5E9"
    },
    "warning": {
      "base": "#FF9800",
      "light": "#FFB74D",
      "dark": "#F57C00",
      "lighter": "#FFF3E0"
    },
    "error": {
      "base": "#FF5252",
      "light": "#FF8A80",
      "dark": "#D32F2F",
      "lighter": "#FFEBEE"
    },
    "neutral": {
      "white": "#FFFFFF",
      "50": "#FAFAFA",
      "100": "#F5F5F5",
      "200": "#EEEEEE",
      "300": "#E0E0E0",
      "400": "#BDBDBD",
      "500": "#9E9E9E",
      "600": "#757575",
      "700": "#616161",
      "800": "#424242",
      "900": "#212121",
      "black": "#000000"
    },
    "background": {
      "primary": "#FFFFFF",
      "secondary": "#F8F9FA",
      "tertiary": "#F0F1F3",
      "overlay": "#00000066",
      "modal": "#FFFFFF"
    },
    "text": {
      "primary": "#212121",
      "secondary": "#616161",
      "tertiary": "#9E9E9E",
      "inverse": "#FFFFFF",
      "disabled": "#BDBDBD",
      "link": "#6C63FF"
    },
    "border": {
      "light": "#E0E0E0",
      "medium": "#BDBDBD",
      "dark": "#757575"
    },
    "special": {
      "gold": "#FFD700",
      "gold_light": "#FFECB3",
      "fire": "#FF6B35",
      "streak_flame": "#FF5722"
    }
  },

  "typography": {
    "font_family": {
      "primary": "PingFang SC",
      "primary_android": "Noto Sans SC",
      "secondary": "SF Pro Display",
      "secondary_android": "Roboto"
    },
    "sizes": {
      "display": {
        "large": { "size": 48, "line_height": 56, "letter_spacing": -0.5 },
        "medium": { "size": 36, "line_height": 44, "letter_spacing": -0.5 },
        "small": { "size": 28, "line_height": 36, "letter_spacing": -0.5 }
      },
      "heading": {
        "1": { "size": 24, "line_height": 32, "letter_spacing": -0.5 },
        "2": { "size": 20, "line_height": 28, "letter_spacing": -0.25 },
        "3": { "size": 18, "line_height": 24, "letter_spacing": 0 },
        "4": { "size": 16, "line_height": 22, "letter_spacing": 0 }
      },
      "body": {
        "large": { "size": 16, "line_height": 24, "letter_spacing": 0 },
        "medium": { "size": 14, "line_height": 20, "letter_spacing": 0 },
        "small": { "size": 12, "line_height": 18, "letter_spacing": 0 },
        "tiny": { "size": 10, "line_height": 14, "letter_spacing": 0.25 }
      }
    },
    "weights": {
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    }
  },

  "spacing": {
    "base": 4,
    "scale": {
      "0": 0,
      "1": 4,
      "2": 8,
      "3": 12,
      "4": 16,
      "5": 20,
      "6": 24,
      "7": 32,
      "8": 40,
      "9": 48,
      "10": 64,
      "11": 80,
      "12": 96
    },
    "inset": {
      "screen_horizontal": 16,
      "screen_vertical": 16,
      "card_padding": 16,
      "button_padding_horizontal": 24,
      "button_padding_vertical": 12,
      "input_padding": 16
    }
  },

  "sizing": {
    "avatar": {
      "small": 32,
      "medium": 40,
      "large": 56,
      "xlarge": 80
    },
    "icon": {
      "tiny": 12,
      "small": 16,
      "medium": 20,
      "large": 24,
      "xlarge": 32,
      "xxlarge": 48
    },
    "button": {
      "height_small": 32,
      "height_medium": 44,
      "height_large": 56,
      "min_width_small": 80,
      "min_width_medium": 120,
      "min_width_large": 160
    },
    "card": {
      "border_radius": 16,
      "padding": 16
    },
    "input": {
      "height": 48,
      "border_radius": 12
    }
  },

  "border_radius": {
    "none": 0,
    "small": 4,
    "medium": 8,
    "large": 12,
    "xlarge": 16,
    "xxlarge": 24,
    "full": 9999
  },

  "shadows": {
    "small": {
      "ios": {
        "shadow_color": "#000000",
        "shadow_offset": { "width": 0, "height": 1 },
        "shadow_opacity": 0.1,
        "shadow_radius": 2
      },
      "android": {
        "elevation": 2
      }
    },
    "medium": {
      "ios": {
        "shadow_color": "#000000",
        "shadow_offset": { "width": 0, "height": 2 },
        "shadow_opacity": 0.15,
        "shadow_radius": 4
      },
      "android": {
        "elevation": 4
      }
    },
    "large": {
      "ios": {
        "shadow_color": "#000000",
        "shadow_offset": { "width": 0, "height": 4 },
        "shadow_opacity": 0.2,
        "shadow_radius": 8
      },
      "android": {
        "elevation": 8
      }
    },
    "floating": {
      "ios": {
        "shadow_color": "#000000",
        "shadow_offset": { "width": 0, "height": 8 },
        "shadow_opacity": 0.25,
        "shadow_radius": 16
      },
      "android": {
        "elevation": 16
      }
    }
  },

  "animation": {
    "duration": {
      "instant": 0,
      "fast": 150,
      "normal": 250,
      "slow": 350,
      "very_slow": 500
    },
    "easing": {
      "default": "ease_in_out",
      "ease_in": "ease_in",
      "ease_out": "ease_out",
      "spring": "spring",
      "bounce": "bounce"
    },
    "spring": {
      "stiffness": 100,
      "damping": 10,
      "mass": 1
    }
  },

  "z_index": {
    "base": 0,
    "card": 1,
    "sticky": 10,
    "dropdown": 100,
    "modal": 200,
    "toast": 300,
    "tooltip": 400
  },

  "breakpoints": {
    "mobile_small": 320,
    "mobile": 375,
    "mobile_large": 414,
    "tablet_small": 600,
    "tablet": 768,
    "tablet_large": 1024
  },

  "components": {
    "button": {
      "primary": {
        "background": "#6C63FF",
        "text": "#FFFFFF",
        "border_radius": 24,
        "height": 48,
        "disabled": {
          "background": "#E0E0E0",
          "text": "#9E9E9E"
        }
      },
      "secondary": {
        "background": "#E8E7FF",
        "text": "#6C63FF",
        "border_radius": 24,
        "height": 48
      },
      "ghost": {
        "background": "transparent",
        "text": "#6C63FF",
        "border": "1px solid #6C63FF",
        "border_radius": 24,
        "height": 48
      },
      "destructive": {
        "background": "#FF5252",
        "text": "#FFFFFF",
        "border_radius": 24,
        "height": 48
      }
    },
    "input": {
      "background": "#FAFAFA",
      "border": "1px solid #E0E0E0",
      "border_focused": "1px solid #6C63FF",
      "border_radius": 12,
      "height": 48,
      "padding": 16,
      "placeholder": "#9E9E9E"
    },
    "card": {
      "background": "#FFFFFF",
      "border_radius": 16,
      "padding": 16,
      "shadow": "shadow_medium"
    },
    "badge": {
      "primary": {
        "background": "#6C63FF",
        "text": "#FFFFFF"
      },
      "success": {
        "background": "#E8F5E9",
        "text": "#00C853"
      },
      "warning": {
        "background": "#FFF3E0",
        "text": "#FF9800"
      },
      "error": {
        "background": "#FFEBEE",
        "text": "#FF5252"
      }
    },
    "tab_bar": {
      "background": "#FFFFFF",
      "active_color": "#6C63FF",
      "inactive_color": "#9E9E9E",
      "height": 56,
      "border_top": "1px solid #EEEEEE"
    },
    "modal": {
      "background": "#FFFFFF",
      "border_radius_top": 24,
      "overlay": "#00000066"
    },
    "toast": {
      "success": {
        "background": "#00C853",
        "text": "#FFFFFF"
      },
      "error": {
        "background": "#FF5252",
        "text": "#FFFFFF"
      },
      "info": {
        "background": "#616161",
        "text": "#FFFFFF"
      }
    }
  },

  "icons": {
    "home": {
      "outlined": "home-outlined",
      "filled": "home-filled"
    },
    "social": {
      "outlined": "people-outlined",
      "filled": "people-filled"
    },
    "plans": {
      "outlined": "clipboard-list-outlined",
      "filled": "clipboard-list-filled"
    },
    "profile": {
      "outlined": "person-outlined",
      "filled": "person-filled"
    },
    "checkin": {
      "outlined": "check-circle-outlined",
      "filled": "check-circle-filled"
    },
    "fire": "flame",
    "calendar": "calendar",
    "clock": "clock",
    "trophy": "trophy",
    "crown": "crown",
    "bell": "bell",
    "settings": "settings",
    "share": "share",
    "add": "plus",
    "close": "x",
    "back": "chevron-left",
    "forward": "chevron-right",
    "more": "more-horizontal",
    "search": "search",
    "filter": "filter",
    "chart": "bar-chart-2",
    "heart": "heart",
    "star": "star",
    "location": "map-pin",
    "camera": "camera",
    "image": "image"
  }
}
